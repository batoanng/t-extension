{
  "name": "developer-assistant-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build-extension-assets.mjs",
    "package:chrome": "pnpm build && node scripts/package-extension.mjs",
    "preview": "vite preview",
    "lint": "eslint src",
    "test": "vitest run",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/chrome": "^0.1.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-react-refresh": "^0.4",
    "globals": "^15",
    "jsdom": "^26",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vite": "^7",
    "vitest": "^3"
  }
}
